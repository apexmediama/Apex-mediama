.nav-logo{font-family:'Rajdhani',sans-serif;font-size:26px;font-weight:700;letter-spacing:4px;color:var(--cyan);}
.nav-logo span{color:var(--white);}
.nav-links{display:flex;gap:32px;align-items:center;}
